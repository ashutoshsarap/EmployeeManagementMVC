@model List<EmployeeVM>
@{
    ViewData["Title"] = "Products";
}

<div class="col-6 text-end">
    <a asp-action="Add" class="btn btn-primary">
        <i class="bi bi-file-plus"></i>Add new employee
    </a>
</div>

<h1>Product List</h1>

@if (Model == null || !Model.Any())
{
    <p>No tasks available.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Position</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.Name</td>
                    <td>@emp.Position</td>
                    <td>@emp.Email</td>
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Employee" asp-action="Update" asp-route-id="@emp.Id" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil-square"></i>Edit
                            </a>
                            <form asp-controller="Employee" asp-action="Delete" asp-route-id="@emp.Id" class="btn btn-primary mx-2">
                                <button type="submit" class="btn-danger">Delete</button>
                             </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}


