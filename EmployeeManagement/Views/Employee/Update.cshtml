@model EmployeeVM

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Edit Employee</h2>
            </hr>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Name" class="p-0"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="texr-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Email" class="p-0"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="texr-danger"></span>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Position" class="p-0"></label>
            <input asp-for="Position" class="form-control" />
            <span asp-validation-for="Position" class="texr-danger"></span>
        </div>
        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-primary form-control">Add</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Employee" asp-action="Update" class="btn btn-outline-secondary form-control">
                    Back to list
                </a>
            </div>
        </div>


    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}